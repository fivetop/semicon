# KV260 PL User LED - 4개 LED
# LED 0
set_property PACKAGE_PIN H12 [get_ports {led_out_tri_o[0]}]
set_property IOSTANDARD LVCMOS33 [get_ports {led_out_tri_o[0]}]

# LED 1
set_property PACKAGE_PIN E10 [get_ports {led_out_tri_o[1]}]
set_property IOSTANDARD LVCMOS33 [get_ports {led_out_tri_o[1]}]

# LED 2
set_property PACKAGE_PIN D10 [get_ports {led_out_tri_o[2]}]
set_property IOSTANDARD LVCMOS33 [get_ports {led_out_tri_o[2]}]

# LED 3
set_property PACKAGE_PIN C11 [get_ports {led_out_tri_o[3]}]
set_property IOSTANDARD LVCMOS33 [get_ports {led_out_tri_o[3]}]
